#!/usr/bin/env python3
"""credproxy: instance manager for the credproxy egress proxy.

A credproxy *instance* is a named, persistent pair of containers -- a
proxy container and a workspace container sharing one netns. Instances
are created once and then started/stopped explicitly; one runs at a
time. All instance state lives under ~/.credproxy/<name>/. See
design-v1.md for the model.

User commands:    create, start, stop, shell, list, delete, config, logs
Harness commands: dev build, dev test, dev reload
  -- for hacking on credproxy itself; these need the repo checkout.

Mount-target paths and the published HTTP port are sourced from the
proxy image's `ENV` declarations (read via `docker inspect`'s
`Config.Env`), so the image is the single source of truth for its own
API. The CLI hardcodes only its own conventions (image tag, instance
home, default workspace image).
"""
from __future__ import annotations

import argparse
import copy
import hashlib
import json
import os
import re
import secrets
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from dataclasses import dataclass
from pathlib import Path

try:
    import yaml
except ImportError:  # resolved lazily so `dev` commands work without it
    yaml = None

# Repo layout: this script lives at <repo>/bin/credproxy. The proxy
# source tree is needed only by the `dev` harness commands and for the
# dev-mode source bind-mount into the proxy container.
REPO_ROOT = Path(__file__).resolve().parent.parent
PROXY_DIR = REPO_ROOT / "proxy"
TESTS_DIR = REPO_ROOT / "tests"

# Home for all instance state. Override with $CREDPROXY_HOME.
CREDPROXY_HOME = Path(
    os.environ.get("CREDPROXY_HOME", Path.home() / ".credproxy")
)

# CLI-only conventions -- names the CLI picks; they don't need to match
# anything in the proxy image.
IMAGE_TAG = "credproxy:dev"
DEFAULT_INSTANCE = "default"
DEFAULT_WORKSPACE_IMAGE = "python:3.12-slim"
DEFAULT_HOME = "/root"

# Instance names become container, volume, and directory names.
_NAME_RE = re.compile(r"[A-Za-z0-9][A-Za-z0-9._-]*$")
SECRET_REF = re.compile(r"\$\{secret:([A-Za-z_][A-Za-z0-9_]*)\}")

CONFIG_TEMPLATE = """\
# credproxy instance config -- see design-v1.md.

# Workspace image. Changing this recreates the workspace on next `start`.
image: {image}

# Where the persistent home volume mounts inside the workspace.
home: {home}

# Host directories bind-mounted into the workspace (optional). Absolute
# paths; ~ is expanded. Edited live on the host, shared with the container.
# mounts:
#   - source: ~/src/myproject
#     target: /workspace/myproject
#     readonly: false

# Hosts to intercept. ${{secret:NAME}} is resolved from the host
# environment when the config is pushed to the proxy.
hosts: {{}}
#   api.github.com:
#     headers:
#       Authorization:
#         placeholder: credproxy_test
#         real: ${{secret:GITHUB_PAT}}
"""


def _fail(msg: str) -> None:
    sys.exit(f"[credproxy] {msg}")


def _say(msg: str) -> None:
    print(f"[credproxy] {msg}", file=sys.stderr, flush=True)


def _require_yaml() -> None:
    if yaml is None:
        _fail("PyYAML is required on the host: pip install pyyaml")


# ---- Image env ---------------------------------------------------------
#
# The proxy image declares its API via Dockerfile `ENV`. The CLI reads
# the values via `docker inspect`'s `Config.Env` so the image is the
# single source of truth.


@dataclass(frozen=True)
class ImageEnv:
    http_port: int
    tmpfs: str
    token: str
    source: str

    @classmethod
    def load(cls, image: str = IMAGE_TAG) -> "ImageEnv":
        try:
            out = subprocess.check_output(
                ["docker", "inspect", image], stderr=subprocess.PIPE
            )
        except subprocess.CalledProcessError:
            _fail(f"image {image} not found; run `credproxy dev build` first")
        env_lines = json.loads(out)[0]["Config"].get("Env") or []
        env = dict(line.split("=", 1) for line in env_lines if "=" in line)
        try:
            return cls(
                http_port=int(env["CREDPROXY_HTTP_PORT"]),
                tmpfs=env["CREDPROXY_TMPFS"],
                token=env["CREDPROXY_TOKEN_PATH"],
                source=env["CREDPROXY_SOURCE"],
            )
        except KeyError as e:
            _fail(
                f"image {image} is missing env var {e}; rebuild with "
                f"`credproxy dev build`"
            )


# ---- Instance ----------------------------------------------------------


@dataclass(frozen=True)
class Instance:
    """An instance's host-side paths and Docker object names, all
    derived from its name."""

    name: str

    @property
    def dir(self) -> Path:
        return CREDPROXY_HOME / self.name

    @property
    def config_path(self) -> Path:
        return self.dir / "config.yaml"

    @property
    def token_path(self) -> Path:
        return self.dir / "auth.token"

    @property
    def proxy_container(self) -> str:
        return f"credproxy-proxy-{self.name}"

    @property
    def ws_container(self) -> str:
        return f"credproxy-ws-{self.name}"

    @property
    def home_volume(self) -> str:
        return f"credproxy-home-{self.name}"

    def exists(self) -> bool:
        return self.config_path.exists()


def _instance(name: str | None) -> Instance:
    name = name or DEFAULT_INSTANCE
    if not _NAME_RE.match(name):
        _fail(
            f"invalid instance name {name!r}: use letters, digits, "
            f"'.', '_', '-' (not starting with a separator)"
        )
    return Instance(name)


# ---- Docker helpers ----------------------------------------------------


def _docker(args: list[str], stream: bool = False) -> None:
    """Run `docker <args>`; _fail with docker's stderr on error. With
    stream=True, docker's output goes straight to the terminal."""
    if stream:
        if subprocess.run(["docker", *args], check=False).returncode != 0:
            _fail(f"docker {args[0]} failed")
        return
    r = subprocess.run(
        ["docker", *args],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.PIPE,
        text=True,
        check=False,
    )
    if r.returncode != 0:
        _fail(f"docker {args[0]} failed: {r.stderr.strip()}")


def _docker_quiet(args: list[str]) -> None:
    """Run `docker <args>`, ignoring failures (best-effort cleanup)."""
    subprocess.run(
        ["docker", *args],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def _inspect(ref: str, fmt: str) -> str | None:
    """`docker inspect -f <fmt> <ref>`; None if the object is absent."""
    r = subprocess.run(
        ["docker", "inspect", "-f", fmt, ref],
        capture_output=True,
        text=True,
        check=False,
    )
    return r.stdout.strip() if r.returncode == 0 else None


def _container_status(name: str) -> str | None:
    """running / exited / created / ... ; None if the container is absent."""
    return _inspect(name, "{{.State.Status}}")


def _running_instances() -> list[str]:
    """Names of instances with a running credproxy container."""
    r = subprocess.run(
        ["docker", "ps", "--filter", "label=credproxy.role",
         "--format", '{{.Label "credproxy.instance"}}'],
        capture_output=True,
        text=True,
        check=False,
    )
    return sorted({line for line in r.stdout.split() if line})


# ---- Token -------------------------------------------------------------


def _ensure_token(inst: Instance) -> None:
    if inst.token_path.exists() and inst.token_path.read_text().strip():
        return
    inst.dir.mkdir(parents=True, exist_ok=True)
    inst.token_path.write_text(secrets.token_hex(16) + "\n")
    # 0644 so uid 31337 in the proxy can read it through the bind mount
    # (multi-user host limitation, documented in CLAUDE.md).
    inst.token_path.chmod(0o644)


def _read_token(inst: Instance) -> str:
    if not inst.token_path.exists():
        _fail(f"token missing: {inst.token_path}")
    token = inst.token_path.read_text().strip()
    if not token:
        _fail(f"token file empty: {inst.token_path}")
    return token


# ---- Instance config ---------------------------------------------------


def _load_config(inst: Instance) -> dict:
    """Parse and validate config.yaml into a normalized dict:
    {image, home, mounts: [{source, target, readonly}], hosts: {...}}."""
    _require_yaml()
    if not inst.exists():
        _fail(f"instance '{inst.name}' not found (no {inst.config_path})")
    raw = yaml.safe_load(inst.config_path.read_text()) or {}
    if not isinstance(raw, dict):
        _fail(f"{inst.config_path}: top level must be a mapping")

    image = raw.get("image") or DEFAULT_WORKSPACE_IMAGE
    if not isinstance(image, str):
        _fail(f"{inst.config_path}: `image` must be a string")

    home = raw.get("home") or DEFAULT_HOME
    if not isinstance(home, str) or not home.startswith("/"):
        _fail(f"{inst.config_path}: `home` must be an absolute path")

    mounts = []
    for i, m in enumerate(raw.get("mounts") or []):
        if not isinstance(m, dict) or "source" not in m or "target" not in m:
            _fail(f"{inst.config_path}: mounts[{i}] needs `source` and `target`")
        src = Path(os.path.expanduser(str(m["source"])))
        if not src.is_absolute():
            _fail(
                f"{inst.config_path}: mounts[{i}].source must be absolute "
                f"(after ~ expansion): {m['source']}"
            )
        if not src.exists():
            _fail(f"{inst.config_path}: mounts[{i}].source does not exist: {src}")
        target = str(m["target"])
        if not target.startswith("/"):
            _fail(f"{inst.config_path}: mounts[{i}].target must be absolute")
        mounts.append({
            "source": str(src),
            "target": target,
            "readonly": bool(m.get("readonly", False)),
        })

    hosts = raw.get("hosts") or {}
    if not isinstance(hosts, dict):
        _fail(f"{inst.config_path}: `hosts` must be a mapping")

    return {"image": image, "home": home, "mounts": mounts, "hosts": hosts}


def _quick_image(inst: Instance) -> str:
    """Best-effort `image` read for `list`, without full validation."""
    try:
        raw = yaml.safe_load(inst.config_path.read_text()) or {}
        return raw.get("image") or DEFAULT_WORKSPACE_IMAGE
    except Exception:
        return "?"


def _workspace_spec_hash(cfg: dict, proxy_id: str | None) -> str:
    """Identity of the workspace container's launch spec. Changing the
    image, home, mounts, or the proxy container (netns peer) yields a
    new hash, which `start` uses to decide whether to recreate."""
    spec = json.dumps(
        {
            "image": cfg["image"],
            "home": cfg["home"],
            "mounts": cfg["mounts"],
            "proxy": proxy_id,
        },
        sort_keys=True,
    )
    return hashlib.sha256(spec.encode()).hexdigest()[:16]


def resolve_string(value: str, where: str) -> str:
    def sub(m: re.Match[str]) -> str:
        name = m.group(1)
        v = os.environ.get(name)
        if v is None:
            _fail(
                f"{where} references ${{secret:{name}}} but {name} is not "
                f"set in the host environment"
            )
        return v

    return SECRET_REF.sub(sub, value)


def resolve_hosts(hosts: dict) -> dict:
    """Resolve ${secret:NAME} refs in `real:` fields against host env.
    Returns a {"hosts": ...} body ready to POST to /admin/config."""
    hosts = copy.deepcopy(hosts)
    for host, h_entry in hosts.items():
        if not isinstance(h_entry, dict):
            continue
        for header, hentry in (h_entry.get("headers") or {}).items():
            if isinstance(hentry, dict) and isinstance(hentry.get("real"), str):
                hentry["real"] = resolve_string(
                    hentry["real"], f"hosts.{host}.headers.{header}.real"
                )
    return {"hosts": hosts}


# ---- Proxy HTTP --------------------------------------------------------


def _http_post_json(url: str, body: bytes, token: str) -> tuple[int, dict]:
    req = urllib.request.Request(
        url,
        data=body,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return resp.status, json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        raw = e.read().decode()
        try:
            return e.code, json.loads(raw)
        except json.JSONDecodeError:
            return e.code, {"error": raw}
    except urllib.error.URLError as e:
        _fail(f"connect error talking to the proxy: {e.reason}")
        raise  # unreachable


def _wait_for_proxy_ready(http_port: int, timeout: float = 15.0) -> None:
    """Poll /health until the proxy answers 200 or `timeout` elapses."""
    deadline = time.monotonic() + timeout
    last_err: Exception | None = None
    while time.monotonic() < deadline:
        try:
            with urllib.request.urlopen(
                f"http://127.0.0.1:{http_port}/health", timeout=1
            ) as resp:
                if resp.status == 200:
                    return
        except (urllib.error.URLError, ConnectionError, TimeoutError) as e:
            last_err = e
        time.sleep(0.1)
    _fail(f"proxy did not become ready within {timeout:.0f}s ({last_err})")


def _push_config(inst: Instance, cfg: dict, http_port: int) -> None:
    """Resolve ${secret:} refs and POST hosts to /admin/config."""
    token = _read_token(inst)
    body = json.dumps(resolve_hosts(cfg["hosts"])).encode()
    status, payload = _http_post_json(
        f"http://127.0.0.1:{http_port}/admin/config", body, token
    )
    if status == 200:
        return
    if status == 401:
        _fail(
            f"proxy rejected the token (HTTP 401); check {inst.token_path}"
        )
    _fail(f"config push failed: HTTP {status}: {payload.get('error', payload)}")


# ---- Lifecycle ---------------------------------------------------------


def _create_instance_files(inst: Instance, image: str) -> None:
    if inst.exists():
        _fail(f"instance '{inst.name}' already exists ({inst.dir})")
    inst.dir.mkdir(parents=True, exist_ok=True)
    inst.config_path.write_text(
        CONFIG_TEMPLATE.format(image=image, home=DEFAULT_HOME)
    )
    _ensure_token(inst)


def _create_proxy(inst: Instance, meta: ImageEnv) -> None:
    args = [
        "run", "-d",
        "--name", inst.proxy_container,
        "--label", "credproxy.role=proxy",
        "--label", f"credproxy.instance={inst.name}",
        "--cap-add", "NET_ADMIN",
        # mode=1777 so the proxy's unprivileged uid can write config.json:
        # the tmpfs dir's default mode is not writable by it, and Docker
        # mounts it differently on `docker run` vs. a later `docker start`.
        "--tmpfs", f"{meta.tmpfs}:size=64k,mode=1777",
        "--mount",
        f"type=bind,source={inst.token_path},target={meta.token},readonly",
        "-p", f"127.0.0.1:{meta.http_port}:{meta.http_port}",
    ]
    # Dev convenience: bind-mount the proxy source so `dev reload` picks
    # up edits. Skipped if run outside the repo checkout.
    if PROXY_DIR.is_dir():
        args += ["-v", f"{PROXY_DIR}:{meta.source}"]
    args.append(IMAGE_TAG)
    _docker(args)


def _create_workspace(inst: Instance, cfg: dict, spec_hash: str) -> None:
    args = [
        "run", "-d",
        "--name", inst.ws_container,
        "--label", "credproxy.role=workspace",
        "--label", f"credproxy.instance={inst.name}",
        "--label", f"credproxy.spec={spec_hash}",
        # Share the proxy's netns so all egress is captured.
        "--network", f"container:{inst.proxy_container}",
        # Persistent home volume; seeded from the image's home on first run.
        "-v", f"{inst.home_volume}:{cfg['home']}",
    ]
    for m in cfg["mounts"]:
        opt = f"type=bind,source={m['source']},target={m['target']}"
        if m["readonly"]:
            opt += ",readonly"
        args += ["--mount", opt]
    # `tail -f /dev/null` keeps the container alive to `exec` into; the
    # image's own CMD is irrelevant to a credproxy workspace. `tail` is
    # used over `sleep infinity` because it works on busybox/alpine too.
    args += [cfg["image"], "tail", "-f", "/dev/null"]
    _docker(args)


def _stop_instance(inst: Instance) -> None:
    """Stop the workspace, then the proxy (the workspace shares the
    proxy's netns). Best-effort -- absent containers are fine. A short
    timeout: PID 1 in both containers ignores SIGTERM, so the default
    10s grace would just delay the SIGKILL."""
    _docker_quiet(["stop", "-t", "1", inst.ws_container])
    _docker_quiet(["stop", "-t", "1", inst.proxy_container])


def _start_instance(inst: Instance) -> None:
    """Idempotently bring the instance to fully-running. Auto-creates
    the instance files if missing. Honors the one-at-a-time rule."""
    if not inst.exists():
        _create_instance_files(inst, DEFAULT_WORKSPACE_IMAGE)
        _say(f"created instance '{inst.name}'")

    meta = ImageEnv.load()
    cfg = _load_config(inst)

    # One instance at a time: stop whatever else is running.
    for other in _running_instances():
        if other != inst.name:
            _say(f"stopping running instance '{other}'")
            _stop_instance(Instance(other))

    _ensure_token(inst)

    # ---- proxy ----
    image_id = _inspect(IMAGE_TAG, "{{.Id}}")
    if image_id is None:
        _fail(f"image {IMAGE_TAG} not found; run `credproxy dev build` first")

    status = _container_status(inst.proxy_container)
    if status is not None and _inspect(inst.proxy_container, "{{.Image}}") != image_id:
        _say("proxy image changed; recreating proxy "
             "(workspace will need re-bootstrap)")
        _docker_quiet(["rm", "-f", inst.proxy_container])
        status = None
    if status is None:
        _say("starting proxy...")
        _create_proxy(inst, meta)
    elif status != "running":
        _docker(["start", inst.proxy_container])

    _wait_for_proxy_ready(meta.http_port)

    # Always re-push: the proxy's tmpfs config does not survive a
    # `docker start`, and re-pushing also picks up `config.yaml` edits.
    _say("pushing config...")
    _push_config(inst, cfg, meta.http_port)

    # ---- workspace ----
    proxy_id = _inspect(inst.proxy_container, "{{.Id}}")
    spec_hash = _workspace_spec_hash(cfg, proxy_id)
    status = _container_status(inst.ws_container)
    if status is not None:
        current = _inspect(
            inst.ws_container, '{{index .Config.Labels "credproxy.spec"}}'
        )
        if current != spec_hash:
            _say("workspace spec changed; recreating workspace")
            _docker_quiet(["rm", "-f", inst.ws_container])
            status = None
    if status is None:
        _say("starting workspace...")
        _create_workspace(inst, cfg, spec_hash)
    elif status != "running":
        _docker(["start", inst.ws_container])


# ---- Commands ----------------------------------------------------------


def cmd_create(args: argparse.Namespace) -> None:
    inst = _instance(args.name)
    _create_instance_files(inst, args.image)
    print(f"created instance '{inst.name}' at {inst.dir}")
    print(f"edit {inst.config_path}, then run `credproxy start {inst.name}`")


def cmd_start(args: argparse.Namespace) -> None:
    inst = _instance(args.name)
    _start_instance(inst)
    print(f"instance '{inst.name}' running")


def cmd_stop(args: argparse.Namespace) -> None:
    inst = _instance(args.name)
    if not inst.exists():
        _fail(f"instance '{inst.name}' not found")
    _stop_instance(inst)
    print(f"instance '{inst.name}' stopped")


def cmd_shell(args: argparse.Namespace) -> None:
    inst = _instance(args.name)
    _start_instance(inst)
    cmd = ["docker", "exec", "-i"]
    if sys.stdin.isatty():
        cmd.append("-t")
    cmd.append(inst.ws_container)
    cmd += args.trailing or ["bash"]
    os.execvp("docker", cmd)


def cmd_list(args: argparse.Namespace) -> None:
    _require_yaml()
    names = (
        sorted(p.name for p in CREDPROXY_HOME.iterdir() if p.is_dir())
        if CREDPROXY_HOME.exists()
        else []
    )
    if not names:
        print("no instances (create one with `credproxy create`)")
        return
    rows = [("NAME", "STATUS", "IMAGE")]
    for name in names:
        inst = Instance(name)
        running = _container_status(inst.ws_container) == "running"
        rows.append((name, "running" if running else "stopped",
                     _quick_image(inst)))
    widths = [max(len(r[i]) for r in rows) for i in range(2)]
    for r in rows:
        print(f"{r[0]:<{widths[0]}}  {r[1]:<{widths[1]}}  {r[2]}")


def cmd_delete(args: argparse.Namespace) -> None:
    inst = _instance(args.name)
    if not inst.exists():
        _fail(f"instance '{inst.name}' not found")
    if not args.yes:
        reply = input(
            f"delete instance '{inst.name}' -- containers, the "
            f"{inst.home_volume} volume, and {inst.dir}? [y/N] "
        )
        if reply.strip().lower() not in ("y", "yes"):
            _fail("aborted")
    _docker_quiet(["rm", "-f", inst.ws_container])
    _docker_quiet(["rm", "-f", inst.proxy_container])
    _docker_quiet(["volume", "rm", inst.home_volume])
    shutil.rmtree(inst.dir, ignore_errors=True)
    print(f"deleted instance '{inst.name}'")


def cmd_config(args: argparse.Namespace) -> None:
    inst = _instance(args.name)
    if not inst.exists():
        _fail(f"instance '{inst.name}' not found")
    if args.action == "show":
        sys.stdout.write(inst.config_path.read_text())
    elif args.action == "edit":
        editor = os.environ.get("EDITOR", "vi")
        subprocess.call([editor, str(inst.config_path)])
    elif args.action == "push":
        if _container_status(inst.proxy_container) != "running":
            _fail(
                f"instance '{inst.name}' is not running; "
                f"`credproxy start {inst.name}` first"
            )
        cfg = _load_config(inst)
        _push_config(inst, cfg, ImageEnv.load().http_port)
        print("config pushed")


def cmd_logs(args: argparse.Namespace) -> None:
    inst = _instance(args.name)
    os.execvp("docker", ["docker", "logs", "-f", inst.proxy_container])


def cmd_dev_build(args: argparse.Namespace) -> None:
    if not PROXY_DIR.is_dir():
        _fail(f"{PROXY_DIR} not found -- `dev` commands need the repo checkout")
    _docker(["build", "-t", IMAGE_TAG, str(PROXY_DIR)], stream=True)


def cmd_dev_test(args: argparse.Namespace) -> None:
    meta = ImageEnv.load()
    cmd = [
        "docker", "run", "--rm",
        "-v", f"{PROXY_DIR}:{meta.source}",
        "-v", f"{TESTS_DIR}:/opt/tests",
        "-w", "/opt",
        "--entrypoint", "python",
        IMAGE_TAG,
        "-m", "pytest", "-v", "tests/",
    ]
    cmd += args.trailing
    os.execvp("docker", cmd)


def cmd_dev_reload(args: argparse.Namespace) -> None:
    inst = _instance(args.name)
    if _container_status(inst.proxy_container) != "running":
        _fail(f"proxy for instance '{inst.name}' is not running")
    _docker(["kill", "--signal=HUP", inst.proxy_container])
    print(f"reloaded proxy for instance '{inst.name}'")


# ---- argparse ----------------------------------------------------------


def _add_name(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "name", nargs="?", default=None,
        help=f"instance name (default: '{DEFAULT_INSTANCE}')",
    )


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="credproxy",
        description="Instance manager for the credproxy egress proxy.",
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser("create", help="scaffold a new instance")
    p.add_argument("name", nargs="?", default=None)
    p.add_argument(
        "--image", default=DEFAULT_WORKSPACE_IMAGE,
        help=f"workspace image (default: {DEFAULT_WORKSPACE_IMAGE})",
    )
    p.set_defaults(func=cmd_create)

    p = sub.add_parser(
        "start", help="start an instance (auto-creates it if missing)"
    )
    _add_name(p)
    p.set_defaults(func=cmd_start)

    p = sub.add_parser("stop", help="stop an instance")
    _add_name(p)
    p.set_defaults(func=cmd_stop)

    p = sub.add_parser(
        "shell",
        help="open a shell in an instance (auto-starts it)",
        description="Open a shell in an instance. Pass a command to run "
                    "instead of bash after a literal `--`.",
    )
    _add_name(p)
    p.set_defaults(func=cmd_shell)

    p = sub.add_parser("list", help="list instances and their status")
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("delete", help="delete an instance and all its state")
    _add_name(p)
    p.add_argument(
        "-y", "--yes", action="store_true", help="skip the confirmation prompt"
    )
    p.set_defaults(func=cmd_delete)

    p = sub.add_parser("config", help="show, edit, or push instance config")
    p.add_argument("action", choices=["show", "edit", "push"])
    _add_name(p)
    p.set_defaults(func=cmd_config)

    p = sub.add_parser("logs", help="follow an instance's proxy logs")
    _add_name(p)
    p.set_defaults(func=cmd_logs)

    dev = sub.add_parser(
        "dev", help="harness commands for hacking on credproxy itself"
    )
    devsub = dev.add_subparsers(dest="devcmd", required=True)
    devsub.add_parser("build", help="docker build the proxy image") \
        .set_defaults(func=cmd_dev_build)
    devsub.add_parser(
        "test",
        help="run pytest in the proxy image",
        description="Run pytest in the proxy image. Pass extra pytest "
                    "args after a literal `--`.",
    ).set_defaults(func=cmd_dev_test)
    p = devsub.add_parser("reload", help="SIGHUP an instance's proxy")
    _add_name(p)
    p.set_defaults(func=cmd_dev_reload)

    argv = sys.argv[1:]
    # A command to run inside a workspace (`shell`) or extra pytest args
    # (`dev test`) follow a literal `--`. Split it off before argparse so
    # it cannot be mistaken for the instance name.
    trailing: list[str] = []
    if "--" in argv:
        i = argv.index("--")
        argv, trailing = argv[:i], argv[i + 1:]

    args = parser.parse_args(argv)
    args.trailing = trailing
    args.func(args)


if __name__ == "__main__":
    main()
