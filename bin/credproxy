#!/usr/bin/env python3
"""credproxy: dev harness CLI for the credproxy egress proxy.

Common case: `credproxy workspace` starts the proxy, pushes config,
runs the workspace container, and tears the proxy down on exit --
single command for an entire session. Surgical commands (build,
start, stop, reload, logs, shell, config, test) exist for keeping
a proxy alive across multiple workspaces or for debugging.

Mount-target paths and the published HTTP port are sourced from
the proxy image's `ENV` declarations (read via `docker inspect`'s
`Config.Env`) rather than hardcoded here, so the image is the
single source of truth for its own API. The CLI hardcodes only its
own conventions (image tag, container name, host-side token path,
default workspace image).
"""
from __future__ import annotations

import argparse
import json
import os
import re
import secrets
import subprocess
import sys
import time
import urllib.error
import urllib.request
from dataclasses import dataclass
from pathlib import Path

# Repo layout: this script lives at <repo>/bin/credproxy.
REPO_ROOT = Path(__file__).resolve().parent.parent
PROXY_DIR = REPO_ROOT / "proxy"
TESTS_DIR = REPO_ROOT / "tests"
TOKEN_FILE = REPO_ROOT / ".run" / "auth.token"
DEFAULT_CONFIG = PROXY_DIR / "config.yaml"

# CLI-only conventions: image tag, container name, default workspace image.
# These don't need to "match" anything in the image -- they're just names
# the CLI picks.
IMAGE_TAG = "credproxy:dev"
CONTAINER_NAME = "credproxy"
DEFAULT_WORKSPACE_IMAGE = "python:3.12-slim"

SECRET_REF = re.compile(r"\$\{secret:([A-Za-z_][A-Za-z0-9_]*)\}")


def _fail(msg: str) -> None:
    sys.exit(f"[credproxy] {msg}")


# ---- Image env ---------------------------------------------------------
#
# The proxy image declares its API via Dockerfile `ENV`. The CLI reads
# the values via `docker inspect`'s `Config.Env` so the image is the
# single source of truth -- the in-container code reads the same vars
# from its inherited process environment.


@dataclass(frozen=True)
class ImageEnv:
    http_port: int
    tmpfs: str
    token: str
    source: str

    @classmethod
    def load(cls, image: str = IMAGE_TAG) -> "ImageEnv":
        try:
            out = subprocess.check_output(
                ["docker", "inspect", image], stderr=subprocess.PIPE
            )
        except subprocess.CalledProcessError:
            _fail(f"image {image} not found; run `credproxy build` first")
        env_lines = json.loads(out)[0]["Config"].get("Env") or []
        env = dict(line.split("=", 1) for line in env_lines if "=" in line)
        try:
            return cls(
                http_port=int(env["CREDPROXY_HTTP_PORT"]),
                tmpfs=env["CREDPROXY_TMPFS"],
                token=env["CREDPROXY_TOKEN_PATH"],
                source=env["CREDPROXY_SOURCE"],
            )
        except KeyError as e:
            _fail(
                f"image {image} is missing env var {e}; rebuild with the "
                f"current Dockerfile (`credproxy build`)"
            )


# ---- helpers -----------------------------------------------------------


def _container_running() -> bool:
    out = subprocess.run(
        ["docker", "ps", "-q", "-f", f"name=^{CONTAINER_NAME}$"],
        capture_output=True,
        text=True,
        check=False,
    )
    return bool(out.stdout.strip())


def _strip_dash_dash(args: list[str] | None) -> list[str]:
    """argparse.REMAINDER captures a leading `--` literally; strip it
    so it doesn't reach the underlying docker command."""
    args = args or []
    return args[1:] if args and args[0] == "--" else args


def _ensure_token() -> None:
    if TOKEN_FILE.exists() and TOKEN_FILE.read_text().strip():
        return
    TOKEN_FILE.parent.mkdir(parents=True, exist_ok=True)
    TOKEN_FILE.write_text(secrets.token_hex(16) + "\n")
    # 0644 so uid 31337 in the container can read it through the bind
    # mount (multi-user host limitation, documented in CLAUDE.md).
    TOKEN_FILE.chmod(0o644)
    print(f"[credproxy] generated {TOKEN_FILE.relative_to(REPO_ROOT)}")


# ---- proxy lifecycle helpers ------------------------------------------
#
# These are the building blocks for the subcommands; cmd_workspace also
# calls them directly when it auto-bootstraps the proxy.


def _start_proxy() -> None:
    """Start the proxy container. Caller is responsible for any
    user-facing status message."""
    if _container_running():
        _fail(
            f"{CONTAINER_NAME} already running -- use `credproxy reload` for "
            f"code changes or `credproxy stop` first"
        )
    meta = ImageEnv.load()
    _ensure_token()
    cmd = [
        "docker", "run", "-d", "--rm",
        "--name", CONTAINER_NAME,
        "--cap-add", "NET_ADMIN",
        "--tmpfs", f"{meta.tmpfs}:size=64k",
        "--mount",
        f"type=bind,source={TOKEN_FILE},target={meta.token},readonly",
        "-v", f"{PROXY_DIR}:{meta.source}",
        "-p", f"127.0.0.1:{meta.http_port}:{meta.http_port}",
        IMAGE_TAG,
    ]
    subprocess.check_call(cmd, stdout=subprocess.DEVNULL)


def _stop_proxy() -> None:
    subprocess.run(
        ["docker", "rm", "-f", CONTAINER_NAME],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def _wait_for_proxy_ready(http_port: int, timeout: float = 15.0) -> None:
    """Poll /health until the proxy answers 200 or `timeout` elapses."""
    deadline = time.monotonic() + timeout
    last_err: Exception | None = None
    while time.monotonic() < deadline:
        try:
            with urllib.request.urlopen(
                f"http://127.0.0.1:{http_port}/health", timeout=1
            ) as resp:
                if resp.status == 200:
                    return
        except (urllib.error.URLError, ConnectionError, TimeoutError) as e:
            last_err = e
        time.sleep(0.1)
    _fail(f"proxy did not become ready within {timeout:.0f}s ({last_err})")


def _push_config(file: Path) -> None:
    """Resolve ${secret:NAME} refs and POST to /admin/config. Silent
    on success; _fail on any error (config not found, unset secrets,
    HTTP error)."""
    try:
        import yaml
    except ImportError:
        _fail("missing PyYAML on host; install with: pip install pyyaml")

    if not file.exists():
        _fail(f"config not found: {file}")
    if not TOKEN_FILE.exists():
        _fail(f"token not found: {TOKEN_FILE} -- proxy not started")

    token = TOKEN_FILE.read_text().strip()
    if not token:
        _fail(f"{TOKEN_FILE} is empty; remove it and retry")

    raw = yaml.safe_load(file.read_text()) or {}
    if not isinstance(raw, dict):
        _fail(f"{file}: top level must be a mapping")
    resolved = resolve_config(raw)

    meta = ImageEnv.load()
    body = json.dumps(resolved).encode()
    status, payload = _http_post_json(
        f"http://127.0.0.1:{meta.http_port}/admin/config", body, token
    )

    if status == 200:
        return
    if status == 401:
        _fail(
            f"proxy rejected our token (HTTP 401). Verify {TOKEN_FILE} is "
            f"readable and is the same file the proxy bind-mounts."
        )
    _fail(f"HTTP {status}: {payload.get('error', payload)}")


# ---- subcommands -------------------------------------------------------


def cmd_build(args: argparse.Namespace) -> None:
    subprocess.check_call(["docker", "build", "-t", IMAGE_TAG, str(PROXY_DIR)])


def cmd_start(args: argparse.Namespace) -> None:
    _start_proxy()
    _wait_for_proxy_ready(ImageEnv.load().http_port)
    print(f"{CONTAINER_NAME} started; run `credproxy config` to push config")


def cmd_stop(args: argparse.Namespace) -> None:
    _stop_proxy()


def cmd_reload(args: argparse.Namespace) -> None:
    if not _container_running():
        _fail(f"{CONTAINER_NAME} not running -- start it with `credproxy start`")
    subprocess.check_call(
        ["docker", "kill", "--signal=HUP", CONTAINER_NAME],
        stdout=subprocess.DEVNULL,
    )


def cmd_logs(args: argparse.Namespace) -> None:
    os.execvp("docker", ["docker", "logs", "-f", CONTAINER_NAME])


def cmd_shell(args: argparse.Namespace) -> None:
    os.execvp(
        "docker",
        ["docker", "exec", "-it", "--user", "0", CONTAINER_NAME, "bash"],
    )


def cmd_workspace(args: argparse.Namespace) -> None:
    """Run a workspace container joined to the proxy netns.

    If the proxy isn't already running, this command starts it (with
    config pushed from proxy/config.yaml) and stops it again when the
    workspace exits. If the proxy was already running (e.g., a manual
    `credproxy start`), it's left alone -- explicit lifecycle wins.
    """
    we_started_proxy = False
    try:
        if not _container_running():
            print("[credproxy] starting proxy...", file=sys.stderr, flush=True)
            _start_proxy()
            we_started_proxy = True
            meta = ImageEnv.load()
            _wait_for_proxy_ready(meta.http_port)
            print("[credproxy] pushing config...", file=sys.stderr, flush=True)
            _push_config(DEFAULT_CONFIG)

        cmd = ["docker", "run", "--rm", "-i"]
        if sys.stdin.isatty():
            cmd.append("-t")
        cmd += [
            "--network", f"container:{CONTAINER_NAME}",
            args.image,
        ]
        cmd.extend(_strip_dash_dash(args.cmd) or ["bash"])
        result = subprocess.run(cmd, check=False)
        sys.exit(result.returncode)
    finally:
        if we_started_proxy:
            print("[credproxy] stopping proxy...", file=sys.stderr, flush=True)
            _stop_proxy()


def cmd_test(args: argparse.Namespace) -> None:
    meta = ImageEnv.load()
    cmd = [
        "docker", "run", "--rm",
        "-v", f"{PROXY_DIR}:{meta.source}",
        "-v", f"{TESTS_DIR}:/opt/tests",
        "-w", "/opt",
        "--entrypoint", "python",
        IMAGE_TAG,
        "-m", "pytest", "-v", "tests/",
    ]
    cmd.extend(_strip_dash_dash(args.pytest_args))
    os.execvp("docker", cmd)


# ---- config push -------------------------------------------------------


def resolve_string(value: str, where: str) -> str:
    def sub(m: re.Match[str]) -> str:
        name = m.group(1)
        v = os.environ.get(name)
        if v is None:
            _fail(
                f"{where} references ${{secret:{name}}} but {name} is not "
                f"set in the host environment"
            )
        return v
    return SECRET_REF.sub(sub, value)


def resolve_config(cfg: dict) -> dict:
    hosts = cfg.get("hosts") or {}
    if not isinstance(hosts, dict):
        return cfg
    for host, h_entry in hosts.items():
        if not isinstance(h_entry, dict):
            continue
        headers = h_entry.get("headers") or {}
        if not isinstance(headers, dict):
            continue
        for header, hentry in headers.items():
            if not isinstance(hentry, dict):
                continue
            real = hentry.get("real")
            if isinstance(real, str):
                hentry["real"] = resolve_string(
                    real, f"hosts.{host}.headers.{header}.real"
                )
    return cfg


def _http_post_json(url: str, body: bytes, token: str) -> tuple[int, dict]:
    req = urllib.request.Request(
        url,
        data=body,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return resp.status, json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        raw = e.read().decode()
        try:
            return e.code, json.loads(raw)
        except json.JSONDecodeError:
            return e.code, {"error": raw}
    except urllib.error.URLError as e:
        _fail(f"connect error: {e.reason}")
        raise  # unreachable


def cmd_config(args: argparse.Namespace) -> None:
    _push_config(Path(args.file))
    print("ok")


# ---- main --------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="credproxy",
        description="Dev harness for the credproxy egress proxy.",
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    sub.add_parser("build", help="docker build the proxy image") \
        .set_defaults(func=cmd_build)
    sub.add_parser("start", help="start the proxy container") \
        .set_defaults(func=cmd_start)
    sub.add_parser("stop", help="stop the proxy container") \
        .set_defaults(func=cmd_stop)
    sub.add_parser("reload", help="SIGHUP the proxy (python re-execs in place)") \
        .set_defaults(func=cmd_reload)
    sub.add_parser("logs", help="follow proxy logs") \
        .set_defaults(func=cmd_logs)
    sub.add_parser("shell", help="root shell inside the proxy container") \
        .set_defaults(func=cmd_shell)

    ws = sub.add_parser(
        "workspace",
        help="run a workspace container; auto-starts the proxy if needed and "
             "tears it down on exit (when this command started it)",
    )
    ws.add_argument("--image", default=DEFAULT_WORKSPACE_IMAGE)
    ws.add_argument(
        "cmd", nargs=argparse.REMAINDER,
        help="optional command to run; defaults to `bash`",
    )
    ws.set_defaults(func=cmd_workspace)

    cfg = sub.add_parser(
        "config",
        help="resolve ${secret:NAME} refs and POST to /admin/config",
    )
    cfg.add_argument(
        "--file", default=str(DEFAULT_CONFIG),
        help=f"YAML config path (default: {DEFAULT_CONFIG.relative_to(REPO_ROOT)})",
    )
    cfg.set_defaults(func=cmd_config)

    test = sub.add_parser("test", help="run pytest in the proxy image")
    test.add_argument(
        "pytest_args", nargs=argparse.REMAINDER,
        help="extra args forwarded to pytest (after `--`)",
    )
    test.set_defaults(func=cmd_test)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
