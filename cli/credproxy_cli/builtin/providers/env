#!/usr/bin/env python3
# credproxy provider: env  —  protocol: docs/reference/providers.md
#
# A provider is a standalone executable speaking the batch protocol. Everything
# specific to THIS provider is the metadata block and the get() function; the
# protocol footer is identical across providers. Copy this file as a starting
# point with `credproxy provider scaffold NAME`.
import json
import os
import sys

# ════ metadata ═══════════════════════════════════════════════════════
NAME = "env"
DESCRIPTION = "Host environment variables"
PROTOCOL_VERSION = 1
HELP = """\
Reads host environment variables.
  ref:     the environment variable NAME (e.g. GITHUB_TOKEN)
  example: --provider env --secret GITHUB_TOKEN
The variable must be set in the shell that runs credproxy.
"""

# ════ fetch one secret (the only provider-specific logic) ═════════════
class NotFound(Exception):
    """A ref that doesn't resolve -> exit 2."""


def get(ref):
    val = os.environ.get(ref)
    if val is None:
        raise NotFound(f"${ref} is not set in the host environment")
    return val


# ════ protocol footer (identical for every provider — skip on a scan) ═
def _fail(msg, code):
    print(f"{NAME} provider: {msg}", file=sys.stderr)
    sys.exit(code)


def main():
    try:
        req = json.load(sys.stdin)
    except Exception as e:
        _fail(f"bad request JSON: {e}", 1)
    if req.get("version") != PROTOCOL_VERSION:
        _fail("unsupported version", 3)
    op = req.get("op")
    if op == "describe":
        json.dump({"description": DESCRIPTION}, sys.stdout)
    elif op == "help":
        json.dump({"help": HELP}, sys.stdout)
    elif op == "get":
        # Partial-failure aware: a per-ref not-found goes into `errors` (which ref,
        # and why) instead of aborting the batch, so one missing secret doesn't mask
        # the ones that resolved.
        values, errors = {}, {}
        for ref in req.get("secrets") or []:
            try:
                values[ref] = get(ref)
            except NotFound as e:
                errors[ref] = str(e)
        resp = {"values": values}
        if errors:
            resp["errors"] = errors
        json.dump(resp, sys.stdout)
        if errors:
            sys.exit(2)
    else:
        _fail("unsupported op", 3)


main()
