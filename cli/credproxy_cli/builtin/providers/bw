#!/usr/bin/env python3
# credproxy provider: bw (Bitwarden)  —  protocol: docs/reference/providers.md
#
# A provider is a standalone executable speaking the batch protocol. Everything
# specific to THIS provider is the metadata block and the get() function; the
# protocol footer is identical across providers. Copy this file as a starting
# point with `credproxy provider scaffold NAME`.
#
# Batch-aware: a `get` request carries every ref the resolve needs, and the CLI
# already groups all bindings on this provider into ONE invocation. So we read
# the whole vault with a single `bw list items` (cached for the invocation) and
# resolve every ref against it in memory -- the costly part (the `bw` process
# startup + a vault decrypt, and an unlock if the vault is locked) is paid once
# per resolve, not once per ref or once per binding.
import json
import os
import subprocess
import sys

# ════ metadata ═══════════════════════════════════════════════════════
NAME = "bw"
DESCRIPTION = "Bitwarden (bw CLI)"
PROTOCOL_VERSION = 1
HELP = """\
Reads secrets from Bitwarden (bw CLI).
  ref:     <item>[#<field>] -- item by name or id; field defaults to `password`
           (also username, uri, totp, notes, or a custom field name). `#` (not
           `/`) delimits the field so item names may contain slashes.
  example: --provider bw --secret github
           --provider bw --secret "aws-prod#access_key_id"
Reuses $BW_SESSION when the vault is unlocked; otherwise prompts for the master
password on the terminal once per invocation. A batch/multi-slot fetch reads the
whole vault in a single `bw` call and unlocks just once. Requires `bw` on PATH
and a logged-in account (`bw login`).
"""


# ════ fetch one secret (the only provider-specific logic) ═════════════
class NotFound(Exception):
    """A ref that doesn't resolve to an item/field -> exit 2."""


class BwError(Exception):
    """A backend failure (bw missing, locked-and-can't-unlock, crash) -> exit 1."""


# Cached for the lifetime of one invocation: (by_id, by_name). The whole point
# of the batch protocol -- `bw list items` runs at most once even when many refs
# are requested.
_VAULT = None


def _bw(args):
    """Run `bw <args>` and capture stdout (the JSON payload). When a controlling
    terminal is available, wire `bw`'s stdin+stderr to it so it can prompt for
    the master password itself when the vault is locked -- a no-op when it's
    already unlocked via an ambient BW_SESSION. Without a terminal (CI, a
    `credproxy push` in a pipeline) run non-interactively, so a locked vault
    fails fast with guidance rather than hanging on a prompt nothing can answer.

    Letting `bw` prompt directly means one call both unlocks AND reads -- no
    separate `bw status`/`bw unlock` round-trips (each its own ~1s process
    startup + vault decrypt). The parent CLI snapshots+restores tty echo around
    the whole fetch, so a `bw` killed mid-prompt can't leave the shell echo-off.

    stdin and stderr get SEPARATE `/dev/tty` handles (mirroring a shell's
    `</dev/tty 2>/dev/tty`); one shared read+write handle wedges bw's password
    prompt (it bails without reading and leaks a stray newline onto stdout)."""
    tty_in = tty_err = None
    try:
        tty_in = open("/dev/tty", "r")
        tty_err = open("/dev/tty", "w")
    except OSError:
        if tty_in is not None:
            tty_in.close()
        tty_in = tty_err = None
    try:
        if tty_in is not None:
            return subprocess.run(["bw", *args], stdin=tty_in, stderr=tty_err,
                                  stdout=subprocess.PIPE, text=True)
        return subprocess.run(["bw", *args], stdin=subprocess.DEVNULL,
                              capture_output=True, text=True)
    finally:
        for f in (tty_in, tty_err):
            if f is not None:
                f.close()


def _load_vault():
    """Fetch + index the vault once per invocation with a single `bw list items`
    -- one decrypt for the whole batch. `bw` prompts for the master password
    itself (on the terminal) when the vault is locked, so this one call unlocks
    AND reads. Returns (by_id, by_name)."""
    global _VAULT
    if _VAULT is not None:
        return _VAULT
    r = _bw(["list", "items"])
    if r.returncode != 0:
        # stderr is only captured on the no-tty path (on a tty it went to the
        # terminal the user is looking at); fall back to guidance when we have
        # nothing to quote.
        detail = (r.stderr or "").strip()
        raise BwError("`bw list items` failed" + (f": {detail}" if detail else
                      " (vault locked with no terminal to unlock it, or logged "
                      "out -- unlock with `bw unlock` and export BW_SESSION, or "
                      "run `bw login`)"))
    try:
        items = json.loads(r.stdout)
    except ValueError as e:
        raise BwError(f"`bw list items` returned non-JSON: {e}")
    by_id, by_name = {}, {}
    for it in items:
        by_id[it["id"]] = it
        by_name.setdefault(it["name"], []).append(it)
    _VAULT = (by_id, by_name)
    return _VAULT


def _extract(item, field):
    login = item.get("login") or {}
    if field == "password":
        v = login.get("password")
    elif field == "username":
        v = login.get("username")
    elif field == "uri":
        uris = login.get("uris") or []
        v = uris[0].get("uri") if uris else None
    elif field == "notes":
        v = item.get("notes")
    elif field == "totp":
        # A TOTP is generated, not stored, so it needs its own `bw get totp`
        # (only refs that actually ask for totp pay this second call). If the
        # list-items call above unlocked interactively (no persisted session), a
        # locked vault re-prompts here -- rare enough for totp refs to accept.
        r = _bw(["get", "totp", item["id"]])
        if r.returncode != 0 or not r.stdout.strip():
            raise NotFound(f"item {item['name']!r} has no TOTP")
        return r.stdout.strip()
    else:
        # A custom field, matched by name.
        for f in item.get("fields") or []:
            if f.get("name") == field:
                return f.get("value") or ""
        raise NotFound(f"item {item['name']!r} has no field {field!r}")
    if v is None:
        raise NotFound(f"item {item['name']!r} has no {field}")
    return v


def get(ref):
    item_ref, sep, field = ref.partition("#")
    field = field if sep else "password"
    if not item_ref:
        raise NotFound(f"empty item in ref {ref!r}")
    by_id, by_name = _load_vault()
    item = by_id.get(item_ref)
    if item is None:
        matches = by_name.get(item_ref, [])
        if len(matches) > 1:
            raise NotFound(
                f"{len(matches)} items named {item_ref!r}; reference it by id"
            )
        item = matches[0] if matches else None
    if item is None:
        raise NotFound(f"no Bitwarden item {item_ref!r}")
    return _extract(item, field)


# ════ protocol footer (identical for every provider — skip on a scan) ═
def _fail(msg, code):
    print(f"{NAME} provider: {msg}", file=sys.stderr)
    sys.exit(code)


def main():
    try:
        req = json.load(sys.stdin)
    except Exception as e:
        _fail(f"bad request JSON: {e}", 1)
    if req.get("version") != PROTOCOL_VERSION:
        _fail("unsupported version", 3)
    op = req.get("op")
    if op == "describe":
        json.dump({"description": DESCRIPTION}, sys.stdout)
    elif op == "help":
        json.dump({"help": HELP}, sys.stdout)
    elif op == "get":
        values = {}
        try:
            for ref in req.get("secrets") or []:
                values[ref] = get(ref)
        except NotFound as e:
            _fail(str(e), 2)
        except BwError as e:
            _fail(str(e), 1)
        json.dump({"values": values}, sys.stdout)
    else:
        _fail("unsupported op", 3)


main()
